# Scravio Email Scraper - Environment Configuration

# Application
PROJECT_NAME="Scravio Email Scraper"
VERSION="1.0.0"
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scravio

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Supabase (Authentication)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Groq AI (Free tier available - https://console.groq.com)
GROQ_API_KEY=

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Scraping Configuration
SCRAPE_TIMEOUT=30
MAX_RETRIES=3
REQUEST_DELAY=2.0

# Email Verification
SMTP_TIMEOUT=10
CATCH_ALL_CHECK_ENABLED=true

# Credits System
FREE_CREDITS_MONTHLY=100
CREDITS_PER_PROFILE=1

# Proxies (optional)
USE_PROXIES=false
# Add proxy URLs separated by commas
# PROXY_LIST=http://proxy1:port,http://proxy2:port

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000